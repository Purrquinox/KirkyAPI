# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/kirky

# ─── Auth ─────────────────────────────────────────────────────────────────────
# URL of the KirkyAuth service used to validate bearer tokens.
# In local development this can point to a local auth instance.
AUTH_API_URL=https://auth.kirky.app

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Required for browser push notifications.
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:hello@yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Apple Push Notifications (APNs) ─────────────────────────────────────────
# Required for iOS push notifications.
# All four values come from your Apple Developer account.
#
# APN_KEY_ID    — 10-character Key ID shown on the key download page
# APN_TEAM_ID   — 10-character Team ID from Membership details
# APN_BUNDLE_ID — Bundle identifier of your iOS app (e.g. com.yourcompany.kirky)
# APN_PRIVATE_KEY — Full contents of your .p8 auth key file.
#                   Paste it as a single line with literal \n between lines,
#                   or use a multi-line value if your host supports it.
# APN_PRODUCTION — Set to "true" for App Store / TestFlight builds.
#                  Leave as "false" for Simulator / development provisioning.
APN_KEY_ID=
APN_TEAM_ID=
APN_BUNDLE_ID=
APN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APN_PRODUCTION=false
